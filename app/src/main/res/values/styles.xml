<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.Travel.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Travel.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Travel.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ThemeOverlay.Travel.Toolbar.Light" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="colorControlNormal">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="ThemeOverlay.Travel.PopupMenu" parent="ThemeOverlay.Material3.Light">
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
        <item name="popupMenuBackground">@drawable/bg_popup_menu</item>
        <item name="popupMenuStyle">@style/Widget.Travel.PopupMenu</item>
    </style>

    <style name="Widget.Travel.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    </style>

    <style name="ThemeOverlay.Travel.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.Travel.DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Travel.DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Travel.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Travel.Dialog.Button.Text</item>
    </style>

    <style name="TextAppearance.Travel.DialogTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextAppearance.Travel.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Travel.Dialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.Travel.Dialog.Button.Text" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Travel.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextAppearance">@style/TextAppearance.Travel.ToolbarTitle</item>
        <item name="theme">@style/ThemeOverlay.Travel.Toolbar.Light</item>
        <item name="popupTheme">@style/ThemeOverlay.Travel.PopupMenu</item>
    </style>

    <style name="TextAppearance.Travel.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/header_title_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.Travel.HeaderSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">#CCFFFFFF</item>
    </style>

    <style name="Widget.Travel.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.Travel.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Travel.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.Travel.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_container</item>
    </style>

    <style name="Widget.Travel.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearance">@style/ShapeAppearance.Travel.Medium</item>
    </style>

    <style name="Widget.Travel.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.Travel.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.Travel.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
    </style>

</resources>
